# NarrateTTS environment configuration
# Copy to .env and adjust. Loaded by start.sh.

# --- TTS (standalone mlx-audio / Kokoro service) ---
TTS_SERVICE_URL=http://macstudio1.lab:8203
# KOKORO_MODEL=mlx-community/Kokoro-82M-bf16
# TTS_VOICE=af_heart

# --- LLM (summaries; leave LLM_SERVICE_URL empty to disable) ---
LLM_SERVICE_URL=https://lumi-omlx.howlab.us
LLM_MODEL=gemma-2-9b-it-4bit
# LLM_API_KEY=

# --- Feed ---
# FEED_TTL_DAYS=7
