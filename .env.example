# NarrateTTS environment configuration
# Copy to .env and adjust. Loaded by start.sh.

# --- TTS (standalone mlx-audio / Kokoro service) ---
TTS_SERVICE_URL=http://macstudio1.lab:8203
# KOKORO_MODEL=mlx-community/Kokoro-82M-bf16
# Default voice used for shortcut/share-sheet captures (web UI can still pick per-item)
TTS_VOICE=af_heart

# --- LLM (summaries; leave LLM_SERVICE_URL empty to disable) ---
LLM_SERVICE_URL=https://omlx.howlab.us
LLM_MODEL=gemma-4-26b-a4b-it-8bit
# LLM_API_KEY=

# --- Feed ---
# FEED_TTL_DAYS=7

# --- Capture (iOS shortcut) ---
# Stable public/tailnet HTTPS URL baked into the "Add to iPhone" shortcut so
# capture works off-LAN. Set this to the TLS endpoint your reverse proxy serves
# (NOT the plain http://host:8090 LAN address). Leave empty to derive per-request.
# PUBLIC_BASE_URL=https://narrate.example.com
